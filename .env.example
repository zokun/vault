# Database
DATABASE_URL="file:./vault.db"

# eBay API (for market value lookup)
# Get your key at https://developer.ebay.com/
EBAY_APP_ID=
EBAY_CLIENT_SECRET=

# Craigslist / local listings (no key needed, uses public search)
# Set to your locale region code
CRAIGSLIST_REGION=sfbay

# Facebook Marketplace (unofficial, optional)
# FB_MARKETPLACE_ENABLED=false

# AI — Item enrichment + recommendations (Claude API)
# Get your key at https://console.anthropic.com/
# Used for: debounced name lookup in add-item form, background enrichment, AI recommendations
ANTHROPIC_API_KEY=

# Google Custom Search API — product image search in add-item form
# 1. Enable "Custom Search API" at https://console.developers.google.com/
# 2. Create a Programmable Search Engine at https://programmablesearchengine.google.com/
#    - Set "Search the entire web" and enable "Image search"
#    - Copy the Search Engine ID (cx) below
# If either key is absent the image picker is silently skipped.
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_CX=

# Notifications — Email (Resend)
# Get your key at https://resend.com/
RESEND_API_KEY=

# Notifications — Web Push (VAPID)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Background jobs cron secret (set to a random string)
# Used to authenticate POST /api/jobs/run
CRON_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
